def euclidean_distance():
    x1, y1, x2, y2 = float(input('x1:')), float(input('y1:')), float(input('x2:')), float(input('y2:'))

    result = math.sqrt((x1 - x2) ** 2 + (y1 - y2) ** 2)

    print(result)

def quadratic_equation():
    print(f'ax^2 + bx + c = 0')
    a, b, c = float(input('a:')), float(input('b:')), float(input('c:'))

    d = b ** 2 - 4 * a * c

    if d < 0:
        print('Нет корней')
    elif d == 0:
        x = -1 * (b / (2 * a))
        print(x)
    else:
        x1 = (-1 * b - math.sqrt(d)) / (2 * a)
        x2 = (-1 * b + math.sqrt(d)) / (2 * a)
        print(min(x1, x2))
        print(max(x1, x2))


def digital_root():
    n = int(input('Введите число для вычисления цифрового корня: '))
    result = 0
    while n != 0:
        result += n % 10
        n //= 10
        if n == 0 and result >= 10:
            n = result
            result = 0

    print('Результат:', result)

