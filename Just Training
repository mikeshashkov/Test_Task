def window():
    for row in range(10):
        for line in range(10):
            if line == 0 or line == 9:
                print('|', end='')
            else:
                if row == 0 or row == 9:
                    print('---', end='')
                else:
                    print('   ', end='')
        print()
def prime_numbers():
    amount = int(input('how many numbers: '))
    numbers_list = []
    for i in range(1, amount+1):
        print(i, 'number:', end='')
        n = int(input())
        numbers_list.append(n)
    count = 0
    prime = None

    for isprime in numbers_list:
        for divider in range(2, isprime):
            if isprime % divider == 0:
                prime = False
                break
            else:
                prime = True
        if prime == True or isprime == 2:
            print(f'{isprime}: yes')
            count += 1

    print('Количество простых чисел в последовательности:', count)
