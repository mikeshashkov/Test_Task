def longer_word():
    string = input('string: ')

    count, max_word, current_max = 0, 0, 0

    for i in string:
        if i == ' ':
            count = 0
            if current_max > max_word:
                max_word = current_max
        else:
            count += 1
            current_max = count

    print('Longer word has', max_word, 'letters')
